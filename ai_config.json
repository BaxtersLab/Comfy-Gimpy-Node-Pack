{
  "enabled_features": {
    "design_reasoning": true,
    "creative_assistance": true,
    "style_analysis": true,
    "workflow_optimization": true,
    "collaborative_sessions": true,
    "feedback_learning": true,
    "model_management": true,
    "prompt_engineering": true,
    "context_analysis": true,
    "creative_memory": true
  },
  "ai_models": {
    "vision_model": "clip-vit-base-patch32",
    "language_model": "microsoft/DialoGPT-medium",
    "style_model": "openai/clip-vit-large-patch14",
    "generation_model": "stabilityai/stable-diffusion-2-1",
    "text_model": "facebook/opt-1.3b",
    "local_processing": true,
    "cloud_fallback": false,
    "auto_load_models": ["clip-vit-base-patch32", "microsoft/DialoGPT-medium"]
  },
  "performance": {
    "max_concurrent_sessions": 5,
    "analysis_timeout": 30,
    "optimization_interval": 60,
    "memory_limit_mb": 1024,
    "model_memory_limit_mb": 2048,
    "cache_size_mb": 512
  },
  "collaboration": {
    "session_timeout": 3600,
    "max_participants": 10,
    "auto_save_interval": 300
  },
  "privacy": {
    "local_only": true,
    "data_retention_days": 30,
    "anonymous_feedback": true
  },
  "learning": {
    "min_feedback_samples": 10,
    "confidence_threshold": 0.7,
    "learning_rate": 0.1
  },
  "model_management": {
    "memory_optimization_interval": 300,
    "unload_unused_after_seconds": 1800,
    "performance_tracking_enabled": true,
    "auto_optimize_memory": true
  },
  "prompt_engineering": {
    "max_prompt_history": 1000,
    "evaluation_enabled": true,
    "variation_count": 3,
    "optimization_rules_enabled": true
  },
  "context_analysis": {
    "cache_enabled": true,
    "cache_size": 500,
    "pattern_learning_enabled": true,
    "user_pattern_tracking": true
  },
  "creative_memory": {
    "episodic_memory_limit": 1000,
    "consolidation_interval": 3600,
    "memory_decay_days": 90,
    "pattern_extraction_enabled": true,
    "feedback_learning_enabled": true
  }
}